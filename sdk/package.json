{
  "name": "@routstr/sdk",
  "version": "0.1.0",
  "description": "Framework-agnostic SDK for Routstr API interactions",
  "main": "index.ts",
  "module": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts",
      "require": "./index.ts"
    },
    "./storage": {
      "types": "./storage/index.ts",
      "import": "./storage/index.ts",
      "require": "./storage/index.ts"
    },
    "./wallet": {
      "types": "./wallet/index.ts",
      "import": "./wallet/index.ts",
      "require": "./wallet/index.ts"
    },
    "./discovery": {
      "types": "./discovery/index.ts",
      "import": "./discovery/index.ts",
      "require": "./discovery/index.ts"
    },
    "./client": {
      "types": "./client/index.ts",
      "import": "./client/index.ts",
      "require": "./client/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^3.1.1",
    "applesauce-core": "^5.1.0",
    "applesauce-relay": "^5.1.0",
    "rxjs": "^7.8.1",
    "zustand": "^5.0.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "keywords": [
    "routstr",
    "ai",
    "llm",
    "mcp",
    "model-context-protocol",
    "cashu",
    "bitcoin",
    "micropayments"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/routstr/routstr-chat"
  }
}
